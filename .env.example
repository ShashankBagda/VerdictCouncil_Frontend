# Backend API URL (FastAPI server from VerdictCouncil_Backend)
# The run_backend script starts uvicorn on port 8001.
# The backend default (Settings.fastapi_port) is 8000.
# Set this to whichever port you actually use.
VITE_API_URL=http://localhost:8001

# Dev only: bypass login and treat the UI as authenticated.
# Set to "true" or "1" then restart `npm run dev`.
VITE_BYPASS_AUTH=false
VITE_BYPASS_AUTH_EMAIL=judge@verdictcouncil.sg
VITE_BYPASS_AUTH_ROLE=judge

# Demo-only intake path and mock pipeline status.
VITE_DEMO_MODE=false

# Polling interval for GET /cases/{id}/status in milliseconds.
VITE_PIPELINE_STATUS_POLL_MS=3000
