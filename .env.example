# ------------------------------------------------------------------- #
# Backend API URL
# ------------------------------------------------------------------- #
# FastAPI is launched by the backend's honcho Procfile.dev on port 8001.
# If you run uvicorn standalone (e.g. `make -C VerdictCouncil_Backend dev`)
# the default is still 8001. Override here if you bind a different port.
VITE_API_URL=http://localhost:8001

# ------------------------------------------------------------------- #
# Dev-only: bypass login
# ------------------------------------------------------------------- #
# Set VITE_BYPASS_AUTH to "true" or "1" to treat the UI as authenticated
# without a real backend session. Restart `npm run dev` after changing.
VITE_BYPASS_AUTH=false
VITE_BYPASS_AUTH_EMAIL=judge@verdictcouncil.sg
VITE_BYPASS_AUTH_ROLE=judge

# ------------------------------------------------------------------- #
# Demo mode + polling
# ------------------------------------------------------------------- #
# VITE_DEMO_MODE=true swaps the intake flow for a scripted demo path and
# serves a mock pipeline-status response (no backend required).
VITE_DEMO_MODE=false

# Poll interval (ms) for GET /api/v1/cases/{id}/status when the SSE stream
# is unavailable. Used by the frontend's usePipelineStatus hook.
VITE_PIPELINE_STATUS_POLL_MS=3000

# ------------------------------------------------------------------- #
# Contract lint (npm run check:contract)
# ------------------------------------------------------------------- #
# Path to the backend's committed OpenAPI snapshot. Defaults to the
# sibling submodule when running inside the orchestration root.
# VC_BACKEND_OPENAPI=../VerdictCouncil_Backend/docs/openapi.json
