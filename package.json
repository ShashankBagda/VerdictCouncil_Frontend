{
  "name": "verdict-council-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "test": "vitest run --config vite.config.js",
    "test:watch": "vitest --config vite.config.js",
    "check:contract": "node scripts/check-api-contract.mjs",
    "check:contract:sse": "node scripts/check-api-contract-sse.mjs",
